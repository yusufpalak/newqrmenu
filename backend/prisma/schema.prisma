// SaaS QR Menu Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Enums
enum Role {
  SUPERADMIN
  ADMIN
  USER
}

enum TranslationRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TranslationRequestEntityType {
  CATEGORY
  SUBCATEGORY
  PRODUCT
  FULL_MENU
}

// User Model
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  tenantId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant?             @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  translationRequests TranslationRequest[]
  media          Media[]

  @@index([tenantId])
  @@index([email])
}

// Tenant Model
model Tenant {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  logo            String?
  description     String?  @db.Text
  defaultLocale   String   @default("tr")
  defaultCurrencyId String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  defaultCurrency Currency?       @relation(fields: [defaultCurrencyId], references: [id])
  users           User[]
  categories      Category[]
  subCategories   SubCategory[]
  products        Product[]
  media           Media[]
  translationRequests TranslationRequest[]

  @@index([slug])
}

// Currency Model
model Currency {
  id        String   @id @default(uuid())
  code      String   @unique // TRY, USD, EUR, GBP
  symbol    String   // ₺, $, €
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenants       Tenant[]
  productPrices ProductPrice[]

  @@index([code])
}

// Category Model
model Category {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  slug        String
  description String?  @db.Text
  image       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subCategories  SubCategory[]
  products       Product[]
  translations   CategoryTranslation[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

// Category Translation Model
model CategoryTranslation {
  id         String @id @default(uuid())
  categoryId String
  locale     String // en, tr, de, ar
  name       String
  description String? @db.Text

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([categoryId])
}

// SubCategory Model
model SubCategory {
  id          String   @id @default(uuid())
  tenantId    String
  categoryId  String
  name        String
  slug        String
  description String?  @db.Text
  image       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category     Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products     Product[]
  translations SubCategoryTranslation[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([categoryId])
  @@index([tenantId, isActive])
}

// SubCategory Translation Model
model SubCategoryTranslation {
  id            String @id @default(uuid())
  subCategoryId String
  locale        String
  name          String
  description   String? @db.Text

  subCategory SubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)

  @@unique([subCategoryId, locale])
  @@index([subCategoryId])
}

// Product Model
model Product {
  id             String   @id @default(uuid())
  tenantId       String
  categoryId     String
  subCategoryId  String?
  name           String
  slug           String
  description    String?  @db.Text
  image          String?
  isActive       Boolean  @default(true)
  isFeatured     Boolean  @default(false)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category       Category            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subCategory    SubCategory?        @relation(fields: [subCategoryId], references: [id], onDelete: SetNull)
  prices         ProductPrice[]
  translations   ProductTranslation[]
  nutrition      ProductNutrition?

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([tenantId, isActive])
  @@index([isFeatured])
}

// Product Translation Model
model ProductTranslation {
  id          String  @id @default(uuid())
  productId   String
  locale      String
  name        String
  description String? @db.Text
  ingredients String? @db.Text

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@index([productId])
}

// Product Price Model
model ProductPrice {
  id              String   @id @default(uuid())
  productId       String
  currencyId      String
  price           Decimal  @db.Decimal(10, 2)
  discountedPrice Decimal? @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  currency Currency @relation(fields: [currencyId], references: [id], onDelete: Restrict)

  @@unique([productId, currencyId])
  @@index([productId])
  @@index([currencyId])
}

// Product Nutrition Model
model ProductNutrition {
  id            String  @id @default(uuid())
  productId     String  @unique
  calories      Float?
  protein       Float?
  carbohydrate  Float?
  fat           Float?
  sugar         Float?
  salt          Float?
  allergens     String? @db.Text
  ingredients   String? @db.Text

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// Translation Request Model
model TranslationRequest {
  id               String                    @id @default(uuid())
  tenantId         String
  requestedByUserId String
  targetLocale     String
  entityType       TranslationRequestEntityType
  entityId         String?
  status           TranslationRequestStatus  @default(PENDING)
  note             String?                   @db.Text
  price            Decimal?                  @db.Decimal(10, 2)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedBy   User   @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([requestedByUserId])
  @@index([status])
}

// Media Model
model Media {
  id           String   @id @default(uuid())
  tenantId     String?
  userId       String?
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  createdAt    DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
}
